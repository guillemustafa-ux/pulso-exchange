# Frontend env vars (Vite). Copy to `.env` for local dev, or set these in the
# Vercel project settings for the deploy. All are build-time (VITE_*), so a
# change requires a rebuild/redeploy.

# Base URL of the PULSO API (apps/api). In local dev leave unset to default to
# http://localhost:8000. In the Vercel deploy, set this to the Render URL, with
# NO trailing slash, e.g. https://pulso-api.onrender.com
VITE_API_URL=

# Optional. WalletConnect / Reown project id (https://cloud.reown.com). Without
# it the app still runs with a demo id; injected wallets (MetaMask) work, but
# WalletConnect QR pairing may be limited.
VITE_WALLETCONNECT_PROJECT_ID=
